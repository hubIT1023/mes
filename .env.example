# Database Settings
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mes_db
DB_USERNAME=mes_user
DB_PASSWORD=mes_secure_password

# pgAdmin Settings
PGADMIN_EMAIL=admin@hubit.online
PGADMIN_PASSWORD=pgadmin_secure_password

# Certbot / Let's Encrypt Automation Settings
# Email address used for Let's Encrypt registration and recovery notifications
CERTBOT_EMAIL=admin@hubit.online

# Set to true to request staging certificates from Let's Encrypt (avoids API rate limits during testing)
CERTBOT_STAGING=false
